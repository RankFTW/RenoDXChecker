                                    </Button>
                                </Grid>

                                <!-- RenoDX row -->
                                <Grid x:Name="DetailRdxRow" x:FieldModifier="internal" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DetailRdxLabel" x:FieldModifier="internal" Grid.Column="0" Text="RenoDX" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="DetailRdxStatus" x:FieldModifier="internal" Grid.Column="1" FontSize="12"
                                               VerticalAlignment="Center" HorizontalTextAlignment="Center"
                                               PointerPressed="DetailRdxStatus_PointerPressed"
                                               PointerEntered="LinkText_PointerEntered" PointerExited="LinkText_PointerExited"/>
                                    <Button x:Name="DetailRdxInfoBtn" x:FieldModifier="internal" Grid.Column="2"
                                            Content="Info" FontSize="11" Padding="6,2,6,2"
                                            Background="{StaticResource SurfaceOverlayBrush}"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32"
                                            Click="InfoButton_Click"/>
                                    <Button x:Name="DetailRdxInstallBtn" x:FieldModifier="internal" Grid.Column="3"
                                            Click="InstallButton_Click"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            CornerRadius="8" FontSize="12" Height="32"/>
                                    <Button x:Name="DetailUeExtendedBtn" x:FieldModifier="internal" Grid.Column="4"
                                            Click="UeExtendedFlyoutItem_Click"
                                            Background="{StaticResource SurfaceOverlayBrush}" Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32" Padding="0"
                                            Opacity="0" IsHitTestVisible="False"
                                            ToolTipService.ToolTip="Toggle UE Extended">
                                        <TextBlock Text="UE" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button x:Name="DetailRdxDeleteBtn" x:FieldModifier="internal" Grid.Column="5"
                                            Click="UninstallButton_Click"
                                            Background="{StaticResource AccentRedBgBrush}" Foreground="{StaticResource AccentRedBrush}"
                                            BorderBrush="{StaticResource AccentPurpleBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32" Padding="0"
                                            ToolTipService.ToolTip="Remove RenoDX mod" Opacity="0" IsHitTestVisible="False">
                                        <TextBlock Text="✕" FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource AccentRedBrush}"/>
                                    </Button>
                                </Grid>

                                <!-- Luma row (shown in Luma mode) -->
                                <Grid x:Name="DetailLumaRow" x:FieldModifier="internal" ColumnSpacing="8" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Luma" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="DetailLumaStatus" x:FieldModifier="internal" Grid.Column="1" FontSize="12"
                                               VerticalAlignment="Center" HorizontalTextAlignment="Center"/>
                                    <Button x:Name="DetailLumaInfoBtn" x:FieldModifier="internal" Grid.Column="2"
                                            Content="Info" FontSize="11" Padding="6,2,6,2"
                                            Background="{StaticResource SurfaceOverlayBrush}"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32"
                                            Click="InfoButton_Click"/>
                                    <Button x:Name="DetailLumaInstallBtn" x:FieldModifier="internal" Grid.Column="3"
                                            Click="InstallLumaButton_Click"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            CornerRadius="8" FontSize="12" Height="32"
                                            BorderThickness="1"/>
                                    <Button x:Name="DetailLumaIniBtn" x:FieldModifier="internal" Grid.Column="4"
                                            Click="LumaIniButton_Click"
                                            Background="{StaticResource SurfaceOverlayBrush}" Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32" Padding="0"
                                            ToolTipService.ToolTip="Copy ReShade.ini to game folder">
                                        <TextBlock Text="📋" FontSize="12" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button x:Name="DetailLumaDeleteBtn" x:FieldModifier="internal" Grid.Column="5"
                                            Click="UninstallLumaButton_Click"
                                            Background="{StaticResource AccentRedBgBrush}" Foreground="{StaticResource AccentRedBrush}"
                                            BorderBrush="{StaticResource AccentPurpleBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32" Padding="0"
                                            ToolTipService.ToolTip="Remove Luma mod" Opacity="0" IsHitTestVisible="False">
                                        <TextBlock Text="✕" FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource AccentRedBrush}"/>
                                    </Button>
                                </Grid>

                                <!-- Labeled separator: choose one limiter -->
                                <Grid Margin="0,4,0,4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="3" Text="———  Frame limiters — Choose one  ———" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- ReLimiter row -->
                                <Grid x:Name="DetailUlRow" x:FieldModifier="internal" ColumnSpacing="8" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DetailUlLabel" x:FieldModifier="internal" Grid.Column="0" Text="ReLimiter" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DetailUlStatus" x:FieldModifier="internal" Grid.Column="1" FontSize="12"
                                               VerticalAlignment="Center" HorizontalTextAlignment="Center"
                                               PointerPressed="DetailUlStatus_PointerPressed"
                                               PointerEntered="LinkText_PointerEntered" PointerExited="LinkText_PointerExited"/>
                                    <Button x:Name="DetailUlInfoBtn" x:FieldModifier="internal" Grid.Column="2"
                                            Content="Info" FontSize="11" Padding="6,2,6,2"
                                            Background="{StaticResource SurfaceOverlayBrush}"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32"
                                            Click="InfoButton_Click"/>
                                    <Button x:Name="DetailUlInstallBtn" x:FieldModifier="internal" Grid.Column="3"
                                            Click="InstallUlButton_Click"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            CornerRadius="8" FontSize="12" Height="32"/>
                                    <Button x:Name="DetailUlIniBtn" x:FieldModifier="internal" Grid.Column="4"
                                            Click="UlIniButton_Click"
                                            Background="{StaticResource SurfaceOverlayBrush}" Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32" Padding="0"
                                            ToolTipService.ToolTip="Copy relimiter.ini to game folder">
                                        <TextBlock Text="📋" FontSize="12" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button x:Name="DetailUlDeleteBtn" x:FieldModifier="internal" Grid.Column="5"
                                            Click="UninstallUlButton_Click"
                                            Background="{StaticResource AccentRedBgBrush}" Foreground="{StaticResource AccentRedBrush}"
                                            BorderBrush="{StaticResource AccentPurpleBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32" Padding="0"
                                            ToolTipService.ToolTip="Remove ReLimiter" Opacity="0" IsHitTestVisible="False">
                                        <TextBlock Text="✕" FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource AccentRedBrush}"/>
                                    </Button>
                                </Grid>

                                <!-- Display Commander row -->
                                <Grid x:Name="DetailDcRow" x:FieldModifier="internal" ColumnSpacing="8" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DetailDcLabel" x:FieldModifier="internal" Grid.Column="0" Text="Display Commander" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DetailDcStatus" x:FieldModifier="internal" Grid.Column="1" FontSize="12"
                                               VerticalAlignment="Center" HorizontalTextAlignment="Center"
                                               PointerPressed="DetailDcStatus_PointerPressed"
                                               PointerEntered="LinkText_PointerEntered" PointerExited="LinkText_PointerExited"/>
                                    <Button x:Name="DetailDcInfoBtn" x:FieldModifier="internal" Grid.Column="2"
                                            Content="Info" FontSize="11" Padding="6,2,6,2"
                                            Background="{StaticResource SurfaceOverlayBrush}"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32"
                                            Click="InfoButton_Click"/>
                                    <Button x:Name="DetailDcInstallBtn" x:FieldModifier="internal" Grid.Column="3"
                                            Click="InstallDcButton_Click"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            CornerRadius="8" FontSize="12" Height="32"/>
                                    <Button x:Name="DetailDcIniBtn" x:FieldModifier="internal" Grid.Column="4"
                                            Click="DcIniButton_Click"
                                            Background="{StaticResource SurfaceOverlayBrush}" Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32" Padding="0"
                                            ToolTipService.ToolTip="Copy DisplayCommander.ini to game folder">
                                        <TextBlock Text="📋" FontSize="12" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button x:Name="DetailDcDeleteBtn" x:FieldModifier="internal" Grid.Column="5"
                                            Click="UninstallDcButton_Click"
                                            Background="{StaticResource AccentRedBgBrush}" Foreground="{StaticResource AccentRedBrush}"
                                            BorderBrush="{StaticResource AccentPurpleBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32" Padding="0"
                                            ToolTipService.ToolTip="Remove Display Commander" Opacity="0" IsHitTestVisible="False">
                                        <TextBlock Text="✕" FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource AccentRedBrush}"/>
                                    </Button>
                                </Grid>

                                <!-- Labeled separator: optional components -->
                                <Grid x:Name="DetailOptionalSeparator" x:FieldModifier="internal" Margin="0,4,0,4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="3" Text="──  Optional  ──" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- OptiScaler row -->
                                <Grid x:Name="DetailOsRow" x:FieldModifier="internal" ColumnSpacing="8" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="DetailOsLabel" x:FieldModifier="internal" Grid.Column="0" Text="OptiScaler" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DetailOsStatus" x:FieldModifier="internal" Grid.Column="1" FontSize="12"
                                               VerticalAlignment="Center" HorizontalTextAlignment="Center"
                                               PointerPressed="DetailOsStatus_PointerPressed"
                                               PointerEntered="LinkText_PointerEntered" PointerExited="LinkText_PointerExited"/>
                                    <Button x:Name="DetailOsInfoBtn" x:FieldModifier="internal" Grid.Column="2"
                                            Content="Info" FontSize="11" Padding="6,2,6,2"
                                            Background="{StaticResource SurfaceOverlayBrush}"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32"
                                            Click="InfoButton_Click"/>
                                    <Button x:Name="DetailOsInstallBtn" x:FieldModifier="internal" Grid.Column="3"
                                            Click="InstallOsButton_Click"
                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            CornerRadius="8" FontSize="12" Height="32"/>
                                    <Button x:Name="DetailOsIniBtn" x:FieldModifier="internal" Grid.Column="4"
                                            Click="CopyOsIniButton_Click"
                                            Background="{StaticResource SurfaceOverlayBrush}" Foreground="{StaticResource TextSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32" Padding="0"
                                            ToolTipService.ToolTip="Copy OptiScaler.ini to game folder">
                                        <TextBlock Text="📋" FontSize="12" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button x:Name="DetailOsDeleteBtn" x:FieldModifier="internal" Grid.Column="5"
                                            Click="UninstallOsButton_Click"
                                            Background="{StaticResource AccentRedBgBrush}" Foreground="{StaticResource AccentRedBrush}"
                                            BorderBrush="{StaticResource AccentPurpleBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32" Padding="0"
                                            ToolTipService.ToolTip="Remove OptiScaler" Opacity="0" IsHitTestVisible="False">
                                        <TextBlock Text="✕" FontSize="12" HorizontalAlignment="Center" Foreground="{StaticResource AccentRedBrush}"/>
                                    </Button>
                                </Grid>

                                <!-- No mod message -->
                                <Border x:Name="DetailNoModMsg" x:FieldModifier="internal" Visibility="Collapsed"
                                        Background="{StaticResource AccentPurpleBgBrush}" CornerRadius="8" Padding="12,8"
                                        BorderBrush="{StaticResource AccentPurpleBorderBrush}" BorderThickness="1">
                                    <TextBlock Text="No RenoDX mod available for this game"
                                               FontSize="12" Foreground="{StaticResource TextDisabledBrush}" TextAlignment="Center"/>
                                </Border>

                                <!-- Progress bars -->
                                <StackPanel x:Name="DetailProgressSection" Spacing="4">
                                    <ProgressBar x:Name="DetailRefProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailRefMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentBlueBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>

                                    <ProgressBar x:Name="DetailRsProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentTealDimBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailRsMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>

                                    <ProgressBar x:Name="DetailUlProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailUlMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentBlueBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>
                                    <ProgressBar x:Name="DetailDcProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailDcMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentBlueBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>
                                    <ProgressBar x:Name="DetailOsProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailOsMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentBlueBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>
                                    <ProgressBar x:Name="DetailRdxProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentBlueBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailRdxMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentBlueBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>
                                    <ProgressBar x:Name="DetailLumaProgress" x:FieldModifier="internal" Visibility="Collapsed"
                                                 Maximum="100" Height="3" CornerRadius="2"
                                                 Foreground="{StaticResource AccentGreenBrush}" Background="{StaticResource SurfaceToolbarBrush}"/>
                                    <TextBlock x:Name="DetailLumaMessage" x:FieldModifier="internal" FontSize="10" Foreground="{StaticResource AccentGreenBrush}"
                                               Visibility="Collapsed" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── Overrides section ── -->
                        <Border x:Name="OverridesContainer" x:FieldModifier="internal"
                                Background="{StaticResource SurfaceComponentTableBrush}" CornerRadius="12"
                                BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1"
                                Padding="14,12" Visibility="Collapsed">
                            <StackPanel x:Name="OverridesPanel" x:FieldModifier="internal" Spacing="6"/>
                        </Border>

                        <!-- ── Management section (folder, reset, report) ── -->
                        <Border x:Name="ManagementContainer" x:FieldModifier="internal"
                                Background="{StaticResource SurfaceComponentTableBrush}" CornerRadius="12"
                                BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1"
                                Padding="14,12" Visibility="Collapsed">
                            <StackPanel x:Name="ManagementPanel" x:FieldModifier="internal" Spacing="6"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                    <!-- Card Grid — visible when grid layout -->
                    <ScrollViewer x:Name="CardGridScrollViewer"
                                  Visibility="{x:Bind ViewModel.CardGridVisibility, Mode=OneWay}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <controls:WrapPanel x:Name="CardGridPanel"
                                            HorizontalSpacing="12" VerticalSpacing="12"
                                            Margin="16"/>
                    </ScrollViewer>

                    <!-- Compact Nav Arrows — overlaid on content area, visible only in Compact mode -->
                    <Button x:Name="CompactNavLeft"
                            Content="◀" Click="CompactNavLeft_Click"
                            VerticalAlignment="Center" HorizontalAlignment="Left"
                            Canvas.ZIndex="1"
                            Visibility="{x:Bind ViewModel.CompactViewVisibility, Mode=OneWay}"
                            Background="{StaticResource SurfaceInputBrush}"
                            Foreground="{StaticResource AccentTealBrush}"
                            BorderBrush="{StaticResource AccentTealBorderBrush}" BorderThickness="1"
                            CornerRadius="8" FontSize="18"
                            Padding="8,16" Margin="4,0"/>

                    <Button x:Name="CompactNavRight"
                            Content="▶" Click="CompactNavRight_Click"
                            VerticalAlignment="Center" HorizontalAlignment="Right"
                            Canvas.ZIndex="1"
                            Visibility="{x:Bind ViewModel.CompactViewVisibility, Mode=OneWay}"
                            Background="{StaticResource SurfaceInputBrush}"
                            Foreground="{StaticResource AccentTealBrush}"
                            BorderBrush="{StaticResource AccentTealBorderBrush}" BorderThickness="1"
                            CornerRadius="8" FontSize="18"
                            Padding="8,16" Margin="0,0,4,0"/>

                    <!-- Skeleton detail panel overlay (removed programmatically after first load) -->
                    <ScrollViewer x:Name="SkeletonDetailScrollViewer" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Visibility="Visible">
                        <StackPanel x:Name="SkeletonDetailPanel" Spacing="16"
                                    Padding="24,18,24,24"/>
                    </ScrollViewer>

                    <!-- Skeleton grid panel overlay (removed programmatically after first load) -->
                    <ScrollViewer x:Name="SkeletonGridScrollViewer" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed">
                        <controls:WrapPanel x:Name="SkeletonGridPanel"
                                            HorizontalSpacing="12" VerticalSpacing="12"
                                            Margin="16"/>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!--  SETTINGS PANEL  -->
            <Grid x:Name="SettingsPanel" x:FieldModifier="internal" Visibility="Collapsed" Background="{StaticResource SurfaceBaseBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Back button bar -->
                <Border Grid.Row="0" Padding="24,12,24,10" Background="Transparent"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Button x:Name="SettingsBackBtn" Content="← Back to Games"
                                Click="SettingsBack_Click"
                                Background="{StaticResource SurfaceOverlayBrush}" Foreground="{StaticResource TextSecondaryBrush}"
                                BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="12,6" FontSize="12"/>
                        <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Scrollable settings content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="32,24,32,40" Spacing="14" MaxWidth="800"
                                HorizontalAlignment="Center">

                        <!-- ── Add Game & Full Refresh ─────────────────────────── -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="0" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: Add Game -->
                                <Grid Grid.Column="0" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Spacing="8">
                                        <TextBlock Text="Add Game" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                                   Text="Manually add a game that wasn't automatically detected. You'll be asked to name it and select the game folder."/>
                                    </StackPanel>
                                    <Button Grid.Row="1" x:Name="AddGameBtn" Content="Add Game"
                                            Click="AddGameButton_Click"
                                            Background="{StaticResource AccentGreenBgBrush}" Foreground="{StaticResource AccentGreenBrush}"
                                            BorderBrush="{StaticResource AccentGreenBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="12,7" FontSize="12"
                                            HorizontalAlignment="Stretch"
                                            ToolTipService.ToolTip="Manually add a game folder"/>
                                </Grid>

                                <!-- Vertical divider -->
                                <Border Grid.Column="1" Width="1"
                                        Background="{StaticResource BorderDefaultBrush}"
                                        VerticalAlignment="Stretch"
                                        Margin="12,0,12,0"/>

                                <!-- Right: Full Refresh -->
                                <Grid Grid.Column="2" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Spacing="8">
                                        <TextBlock Text="Full Refresh" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}"
                                                   Text="Clears all caches and re-scans everything from disk. Use this if games or mods appear out of sync."/>
                                    </StackPanel>
                                    <Button Grid.Row="1" x:Name="FullRefreshBtn" Content="Full Refresh"
                                            Click="FullRefreshButton_Click"
                                            Background="{StaticResource AccentBlueBgBrush}" Foreground="{StaticResource AccentBlueBrush}"
                                            BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="12,7" FontSize="12"
                                            HorizontalAlignment="Stretch"
                                            ToolTipService.ToolTip="Full refresh — clears all caches and re-scans everything from disk"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- ── Screenshots & Hotkeys ─────────────────────────────── -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="0" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- Row 0: Titles + descriptions -->
                                    <RowDefinition Height="Auto"/>  <!-- Row 1: Path box + Open | ReShade keys -->
                                    <RowDefinition Height="Auto"/>  <!-- Row 2: Per-Game label | Apply ReShade Keys -->
                                    <RowDefinition Height="Auto"/>  <!-- Row 3: Per-Game toggle | ReLimiter label + key -->
                                    <RowDefinition Height="Auto"/>  <!-- Row 4: Apply screenshot | ReLimiter Apply -->
                                </Grid.RowDefinitions>

                                <!-- ── Row 0: Titles + descriptions ── -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Screenshots" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                               Text="Set a screenshot save path that will be written to all managed reshade.ini files."/>
                                </StackPanel>

                                <Border Grid.Row="0" Grid.RowSpan="5" Grid.Column="1" Width="1"
                                        Background="{StaticResource BorderDefaultBrush}"
                                        VerticalAlignment="Stretch"
                                        Margin="12,0,12,0"/>

                                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Hotkeys" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                               Text="ReShade key bindings."/>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="11"
                                                   Foreground="{StaticResource InlineDescriptionBrush}"
                                                   Text="Overlay toggle key"/>
                                        <TextBlock Grid.Column="1" FontSize="11"
                                                   Foreground="{StaticResource InlineDescriptionBrush}"
                                                   Text="Screenshot key" Margin="0,0,26,0"/>
                                    </Grid>
                                </StackPanel>

                                <!-- ── Row 1: Path box + Open | ReShade overlay + screenshot keys side by side ── -->
                                <Grid Grid.Row="1" Grid.Column="0" ColumnSpacing="8" VerticalAlignment="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <TextBox x:Name="ScreenshotPathBox" x:FieldModifier="internal"
                                                 PlaceholderText="D:\Screenshots"
                                                 FontSize="12"
                                                 Padding="12,8,36,8"
                                                 Background="{StaticResource SurfaceInputBrush}"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 BorderBrush="{StaticResource BorderSubtleBrush}"/>
                                        <Button Click="BrowseScreenshotPath_Click"
                                                Background="Transparent" BorderThickness="0"
                                                Padding="8,6" MinWidth="0" MinHeight="0"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Margin="0,0,4,0"
                                                ToolTipService.ToolTip="Pick a folder for screenshots">
                                            <FontIcon Glyph="&#xED25;" FontSize="14"
                                                      Foreground="{StaticResource TextTertiaryBrush}"/>
                                        </Button>
                                    </Grid>
                                    <Button Grid.Column="1" Content="Open" Click="OpenScreenshotFolder_Click"
                                            Background="{StaticResource AccentBlueBgBrush}" Foreground="{StaticResource AccentBlueBrush}"
                                            BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="12,6" FontSize="12"
                                            ToolTipService.ToolTip="Open the screenshot folder in Explorer"/>
                                </Grid>

                                <Grid Grid.Row="1" Grid.Column="2" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" x:Name="HotkeyBox" x:FieldModifier="internal"
                                             PlaceholderText="Press a key..."
                                             IsReadOnly="True" FontSize="12"
                                                 Background="{StaticResource SurfaceInputBrush}"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 BorderBrush="{StaticResource BorderSubtleBrush}"
                                                 PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                    <Grid Grid.Column="1" ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="ScreenshotHotkeyBox" x:FieldModifier="internal"
                                                 PlaceholderText="Press a key..."
                                                 IsReadOnly="True" FontSize="12"
                                                 Background="{StaticResource SurfaceInputBrush}"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 BorderBrush="{StaticResource BorderSubtleBrush}"
                                                 PreviewKeyDown="ScreenshotHotkeyBox_PreviewKeyDown"/>
                                        <Button Grid.Column="1" Content="↺" Click="ResetScreenshotHotkey_Click"
                                                ToolTipService.ToolTip="Reset to Print Screen"
                                                Background="Transparent" BorderThickness="0"
                                                Padding="6,4" MinWidth="0" MinHeight="0" FontSize="14"
                                                Foreground="{StaticResource TextTertiaryBrush}"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Grid>

                                <!-- ── Row 2: Per-Game label | Combined Apply ReShade Keys ── -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Per-Game Subfolder"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Bottom"/>

                                <Button Grid.Row="2" Grid.Column="2" x:Name="ApplyHotkeyBtn" x:FieldModifier="internal"
                                        Content="Apply to All Games"
                                        Click="ApplyReShadeHotkeys_Click"
                                        Background="{StaticResource AccentBlueBgBrush}"
                                        Foreground="{StaticResource AccentBlueBrush}"
                                        BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="12,7" FontSize="12"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"/>

                                <!-- ── Row 3: Per-Game toggle | ReLimiter label + key ── -->
                                <ToggleSwitch Grid.Row="3" Grid.Column="0" x:Name="PerGameScreenshotToggle" x:FieldModifier="internal"
                                              OnContent="Enabled — each game gets its own subfolder"
                                              OffContent="Disabled — all screenshots in one folder"
                                              Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                                              VerticalAlignment="Center"/>

                                <StackPanel Grid.Row="3" Grid.Column="2" Spacing="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="11"
                                                   Foreground="{StaticResource InlineDescriptionBrush}"
                                                   Text="ReLimiter OSD toggle key"
                                                   VerticalAlignment="Bottom"/>
                                        <TextBlock Grid.Column="1" FontSize="11"
                                                   Foreground="{StaticResource InlineDescriptionBrush}"
                                                   Text="Shared OSD Presets"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Bottom"/>
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="UlHotkeyBox" x:FieldModifier="internal"
                                                 PlaceholderText="Press a key..."
                                                 IsReadOnly="True"
                                                 FontSize="12"
                                                 Background="{StaticResource SurfaceInputBrush}"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 BorderBrush="{StaticResource BorderSubtleBrush}"
                                                 PreviewKeyDown="UlHotkeyBox_PreviewKeyDown"/>
                                        <ToggleSwitch Grid.Column="1" x:Name="UlSharedPresetsToggle" x:FieldModifier="internal"
                                                      OnContent="On" OffContent="Off"
                                                      Foreground="{StaticResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      MinHeight="0"
                                                      Margin="12,0,0,0"
                                                      VerticalAlignment="Center"
                                                      Toggled="UlSharedPresetsToggle_Toggled"/>
                                    </Grid>
                                </StackPanel>

                                <!-- ── Row 4: Apply screenshot path | ReLimiter Apply ── -->
                                <Button Grid.Row="4" Grid.Column="0" x:Name="ApplyScreenshotPathBtn"
                                        Content="Apply to All Games"
                                        Click="ApplyScreenshotPath_Click"
                                        Background="{StaticResource AccentBlueBgBrush}"
                                        Foreground="{StaticResource AccentBlueBrush}"
                                        BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="12,7" FontSize="12"
                                        HorizontalAlignment="Stretch"/>

                                <Button Grid.Row="4" Grid.Column="2" x:Name="ApplyUlHotkeyBtn" x:FieldModifier="internal"
                                        Content="Apply to All Games"
                                        Click="ApplyUlOsdHotkey_Click"
                                        Background="{StaticResource AccentBlueBgBrush}"
                                        Foreground="{StaticResource AccentBlueBrush}"
                                        BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="12,7" FontSize="12"
                                        HorizontalAlignment="Stretch"/>

                            </Grid>
                        </Border>

                        <!-- ── OptiScaler Settings ─────────────────────────────────── -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="0" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- Row 0: Titles + descriptions -->
                                    <RowDefinition Height="Auto"/>  <!-- Row 1: GPU combo | OS hotkey combo -->
                                    <RowDefinition Height="Auto"/>  <!-- Row 2: DLSS toggle | OS Apply -->
                                    <RowDefinition Height="Auto"/>  <!-- Row 3: Compatibility link -->
                                </Grid.RowDefinitions>

                                <!-- ── Row 0: Titles + descriptions ── -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="OptiScaler Settings" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                               Text="Configure GPU type and DLSS input settings for OptiScaler installations. DLSS input toggle is for AMD/Intel GPUs only — NVIDIA users do not need it."/>
                                </StackPanel>

                                <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="1" Width="1"
                                        Background="{StaticResource BorderDefaultBrush}"
                                        VerticalAlignment="Stretch"
                                        Margin="12,0,12,0"/>

                                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                                    <TextBlock Text="Hotkey" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                               Text="OptiScaler overlay toggle key"/>
                                </StackPanel>

                                <!-- ── Row 1: GPU combo | OS hotkey combo ── -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="GPU Type" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <ComboBox x:Name="OsGpuCombo" x:FieldModifier="internal"
                                              FontSize="12"
                                              HorizontalAlignment="Stretch"
                                              Background="{StaticResource SurfaceInputBrush}"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              BorderBrush="{StaticResource BorderSubtleBrush}"
                                              SelectionChanged="OsGpuCombo_SelectionChanged">
                                        <x:String>NVIDIA</x:String>
                                        <x:String>AMD</x:String>
                                        <x:String>Intel</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <ComboBox Grid.Row="1" Grid.Column="2" x:Name="OsHotkeyCombo" x:FieldModifier="internal"
                                          FontSize="12"
                                          HorizontalAlignment="Stretch"
                                          Background="{StaticResource SurfaceInputBrush}"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          BorderBrush="{StaticResource BorderSubtleBrush}"
                                          SelectionChanged="OsHotkeyCombo_SelectionChanged">
                                    <x:String>Insert</x:String>
                                    <x:String>Home</x:String>
                                    <x:String>End</x:String>
                                    <x:String>Delete</x:String>
                                    <x:String>Page Up</x:String>
                                    <x:String>Page Down</x:String>
                                    <x:String>F1</x:String>
                                    <x:String>F2</x:String>
                                    <x:String>F3</x:String>
                                    <x:String>F4</x:String>
                                    <x:String>F5</x:String>
                                    <x:String>F6</x:String>
                                    <x:String>F7</x:String>
                                    <x:String>F8</x:String>
                                    <x:String>F9</x:String>
                                    <x:String>F10</x:String>
                                    <x:String>F11</x:String>
                                    <x:String>F12</x:String>
                                </ComboBox>

                                <!-- ── Row 2: DLSS toggle | OS Apply ── -->
                                <ToggleSwitch Grid.Row="2" Grid.Column="0" x:Name="OsDlssInputsToggle" x:FieldModifier="internal"
                                              Header="Use DLSS inputs"
                                              OnContent="Enabled — spoofing active"
                                              OffContent="Disabled — no spoofing"
                                              Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                                              VerticalAlignment="Center"
                                              Visibility="Collapsed"
                                              Toggled="OsDlssInputsToggle_Toggled"/>

                                <Button Grid.Row="2" Grid.Column="2" x:Name="ApplyOsHotkeyBtn" x:FieldModifier="internal"
                                        Content="Apply to All Games"
                                        Click="ApplyOsHotkey_Click"
                                        Background="{StaticResource AccentBlueBgBrush}"
                                        Foreground="{StaticResource AccentBlueBrush}"
                                        BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="12,7" FontSize="12"
                                        HorizontalAlignment="Stretch"/>

                                <HyperlinkButton Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                                 Content="OptiScaler Compatibility List"
                                                 NavigateUri="https://github.com/optiscaler/OptiScaler/wiki/Compatibility-List"
                                                 FontSize="12"
                                                 Foreground="{StaticResource AccentBlueBrush}"
                                                 HorizontalAlignment="Left"
                                                 Padding="0,4"/>
                            </Grid>
                        </Border>

                        <!-- ── Global Update Checks ────────────────────────────────── -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Global Update Checks" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                               Text="Disable update checks for individual components. When disabled, the component will not be checked for updates during startup or when using Update All."/>
                                </StackPanel>

                                <Grid ColumnSpacing="16" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <ToggleSwitch Grid.Row="0" Grid.Column="0"
                                                  x:Name="GlobalRdxUpdateToggle" x:FieldModifier="internal"
                                                  Header="RenoDX"
                                                  OnContent="On" OffContent="Off"
                                                  Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                                                  Toggled="GlobalRdxUpdateToggle_Toggled"/>

                                    <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                                  x:Name="GlobalRsUpdateToggle" x:FieldModifier="internal"
                                                  Header="ReShade"
                                                  OnContent="On" OffContent="Off"
                                                  Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                                                  Toggled="GlobalRsUpdateToggle_Toggled"/>

                                    <ToggleSwitch Grid.Row="0" Grid.Column="2"
                                                  x:Name="GlobalUlUpdateToggle" x:FieldModifier="internal"
                                                  Header="ReLimiter"
                                                  OnContent="On" OffContent="Off"
                                                  Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                                                  Toggled="GlobalUlUpdateToggle_Toggled"/>

                                    <ToggleSwitch Grid.Row="1" Grid.Column="0"
                                                  x:Name="GlobalDcUpdateToggle" x:FieldModifier="internal"
                                                  Header="Display Commander"
                                                  OnContent="On" OffContent="Off"
                                                  Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                                                  Toggled="GlobalDcUpdateToggle_Toggled"/>

                                    <ToggleSwitch Grid.Row="1" Grid.Column="1"
                                                  x:Name="GlobalOsUpdateToggle" x:FieldModifier="internal"
                                                  Header="OptiScaler"
                                                  OnContent="On" OffContent="Off"
                                                  Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                                                  Toggled="GlobalOsUpdateToggle_Toggled"/>

                                    <ToggleSwitch Grid.Row="1" Grid.Column="2"
                                                  x:Name="GlobalRefUpdateToggle" x:FieldModifier="internal"
                                                  Header="RE Framework"
                                                  OnContent="On" OffContent="Off"
                                                  Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                                                  Toggled="GlobalRefUpdateToggle_Toggled"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── Custom Shaders & Addon Watch Folder ─────────────────── -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="0" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: Custom Shaders -->
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Spacing="8">
                                        <TextBlock Text="Custom Shaders" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                                   Text="Use your own shader and texture files from a custom directory instead of the built-in shader packs. Files are sourced from %LocalAppData%\RHI\reshade\Custom\."/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Row="1" x:Name="CustomShadersToggle" x:FieldModifier="internal"
                                                  Header="Use Custom Shaders"
                                                  Toggled="CustomShadersToggle_Toggled"
                                                  OnContent="Enabled — deploying from custom directories"
                                                  OffContent="Disabled — using shader packs"
                                                  Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                                                  Margin="0,8,0,0"/>
                                </Grid>

                                <!-- Vertical divider -->
                                <Border Grid.Column="1" Width="1"
                                        Background="{StaticResource BorderDefaultBrush}"
                                        VerticalAlignment="Stretch"
                                        Margin="12,0,12,0"/>

                                <!-- Right: Addon Watch Folder -->
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Spacing="8">
                                        <TextBlock Text="Addon Watch Folder" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}"
                                                   Text="RHI watches this folder for RenoDX addon files (.addon64/.addon32) and archives containing them. Defaults to your Downloads folder."/>
                                    </StackPanel>
                                    <Grid Grid.Row="1" ColumnSpacing="8" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="AddonWatchFolderBox" x:FieldModifier="internal"
                                                 Grid.Column="0"
                                                 PlaceholderText="Downloads folder (default)"
                                                 FontSize="12"
                                                 Background="{StaticResource SurfaceInputBrush}"
                                                 Foreground="{StaticResource TextSecondaryBrush}"
                                                 BorderBrush="{StaticResource BorderSubtleBrush}"/>
                                        <Button Grid.Column="1" Content="Browse" Click="BrowseAddonWatchFolder_Click"
                                                Background="{StaticResource AccentBlueBgBrush}" Foreground="{StaticResource AccentBlueBrush}"
                                                BorderBrush="{StaticResource AccentBlueBorderBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="12,6" FontSize="12"/>
                                        <Button Grid.Column="2" Content="Reset" Click="ResetAddonWatchFolder_Click"
                                                Background="{StaticResource SurfaceInputBrush}" Foreground="{StaticResource TextTertiaryBrush}"
                                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="12,6" FontSize="12"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- ── Shader Cache ────────────────────────────────────────── -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
                                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="8">
                                    <TextBlock Text="Shader Cache" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource InlineDescriptionBrush}" LineHeight="18"
                                               Text="When enabled, all shader packs are downloaded and cached on startup. When disabled, shader packs are only downloaded when needed (e.g. when you select them or install ReShade). Existing cached shaders are kept either way."/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              x:Name="CacheAllShadersToggle" x:FieldModifier="internal"
                                              Header="Cache All Shaders"
                                              Toggled="CacheAllShadersToggle_Toggled"
                                              OnContent="On" OffContent="Off"
                                              Foreground="{StaticResource TextTertiaryBrush}" FontSize="12"
                                              VerticalAlignment="Center"
                                              Margin="16,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- ── Mass INI Deployment ─────────────────────────────────── -->
                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="10" Padding="20,16"
