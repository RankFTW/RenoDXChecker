        <!-- end Row 1 content area -->

        <!--  ROW 2: STATUS BAR  -->
        <Border Grid.Row="2" Padding="20,6" Background="{StaticResource SurfaceStatusBarBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusBarText" Text=""
                           FontSize="11" Foreground="{StaticResource TextDisabledBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="10" Foreground="{StaticResource AccentAmberDimBrush}"
                           TextTrimming="CharacterEllipsis" MaxLines="1"
                           Text="⚠ Single-player only — ReShade with addon support and OptiScaler may trigger anti-cheat in online/multiplayer games"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="8">
                    <TextBlock x:Name="StatusBarVersionText" x:FieldModifier="internal"
                               FontSize="11" Foreground="{StaticResource TextDisabledBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="Patch Notes"
                            Click="PatchNotesLink_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextDisabledBrush}" FontSize="11"
                            Padding="8,2" VerticalAlignment="Center"
                            ToolTipService.ToolTip="View recent patch notes"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- (Old card DataTemplate removed — detail panel is now built in code-behind) -->
    </Grid>
</Window>
