                                            BorderBrush="{StaticResource AccentPurpleBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Width="36" Height="32" Padding="0"
                                            ToolTipService.ToolTip="Remove ReShade" Opacity="0" IsHitTestVisible="False">
